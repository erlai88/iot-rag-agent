# Embedding provider (required for ingest + retrieval)
EMBEDDING_API_KEY=your_embedding_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional if your embedding provider is OpenAI-compatible but not OpenAI official endpoint
# EMBEDDING_BASE_URL=

# LLM provider for answer generation
# If omitted, chain.py will fallback to OPENAI_API_KEY / DEEPSEEK_API_KEY
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4.1-mini

# Backward-compatible defaults
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
